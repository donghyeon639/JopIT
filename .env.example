# 로컬 개발용 환경변수 예시.
# 복사 후 실제 값을 채워서 `.env`로 사용하거나, IDE Run Configuration에 직접 등록한다.
# 실제 값이 들어간 .env / application-local.properties 는 절대 커밋 금지.

# ===== DataSource =====
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# ===== JWT (32자 이상) =====
JWT_SECRET=change-me-locally-must-be-at-least-32-characters

# ===== GitHub API (이슈 등록용) =====
GITHUB_TOKEN=
GITHUB_OWNER=donghyeon639
GITHUB_REPO=JopIT

# ===== 공공 채용 (ALIO) — 공공데이터포털 발급 키 =====
PUBLIC_JOB_ALIO_API_KEY=

# ===== 소셜 로그인 =====
APP_SOCIAL_REDIRECT_URI=http://localhost:5173/social/callback
APP_SOCIAL_FAILURE_REDIRECT_URI=http://localhost:5173/login?reason=social_failed

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=